<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">


    <!-- Панель управления периодом -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="?attr/colorSurface">

        <Button
            android:id="@+id/prevMonthButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="◀"
            android:background="@android:color/transparent"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/periodTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Апрель 2026"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/nextMonthButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="▶"
            android:background="@android:color/transparent"
            android:textSize="24sp" />


        <ImageButton
            android:id="@+id/calendarButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_baseline_calendar_24"
            android:background="@android:color/transparent"
            android:contentDescription="Выбрать период" />

    </LinearLayout>

    <!-- Таблица -->
    <HorizontalScrollView
        android:id="@+id/tableScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/tableContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Фиксированные колонки -->
            <LinearLayout
                android:id="@+id/fixedColumnsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Динамические колонки -->
            <HorizontalScrollView
                android:id="@+id/dynamicColumnsScroll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/dynamicColumnsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </HorizontalScrollView>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Прогресс загрузки -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <!-- Сообщение при отсутствии данных -->
    <TextView
        android:id="@+id/emptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:text="Нет данных за выбранный период"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>