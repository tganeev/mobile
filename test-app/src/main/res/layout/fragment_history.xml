<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Панель управления периодом -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="?attr/colorSurface">

        <Button
            android:id="@+id/prevMonthButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="◀"
            android:background="@android:color/transparent"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/periodTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Апрель 2026"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/nextMonthButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="▶"
            android:background="@android:color/transparent"
            android:textSize="24sp" />

        <ImageButton
            android:id="@+id/calendarButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_baseline_calendar_24"
            android:background="@android:color/transparent"
            android:contentDescription="Выбрать период" />

    </LinearLayout>

    <!-- Поле поиска -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:layout_marginTop="0dp"
        android:hint="Поиск по названию книги"
        app:boxCornerRadiusBottomEnd="24dp"
        app:boxCornerRadiusBottomStart="24dp"
        app:boxCornerRadiusTopEnd="24dp"
        app:boxCornerRadiusTopStart="24dp"
        app:endIconMode="clear_text"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/searchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:cursorVisible="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Кнопка Статистика -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/statsToggleButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:text="📊 Статистика"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="@android:color/white"
        app:icon="@drawable/ic_baseline_show_chart_24"
        app:iconGravity="textStart" />

    <!-- Вертикальный скролл для таблицы -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Фиксированная колонка -->
            <LinearLayout
                android:id="@+id/fixedColumnContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:elevation="4dp"
                android:background="?attr/colorSurface" />

            <!-- Горизонтальный скролл для остальных колонок -->
            <HorizontalScrollView
                android:id="@+id/tableScrollView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="horizontal">

                <LinearLayout
                    android:id="@+id/dynamicColumnsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </HorizontalScrollView>

        </LinearLayout>

    </ScrollView>

    <!-- Прогресс загрузки -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <!-- Сообщение при отсутствии данных -->
    <TextView
        android:id="@+id/emptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:text="Нет данных за выбранный период"
        android:textSize="16sp"
        android:visibility="gone" />

</LinearLayout>