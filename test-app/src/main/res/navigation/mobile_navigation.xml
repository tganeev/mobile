<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/menu_fragment">

    <!-- Главное меню -->
    <fragment
        android:id="@+id/menu_fragment"
        android:name="org.readium.r2.testapp.ui.menu.MenuFragment"
        android:label="PKMS"
        tools:layout="@layout/fragment_menu" />

    <!-- Библиотека (ранее Читалка) -->
    <fragment
        android:id="@+id/bookshelf_fragment"
        android:name="org.readium.r2.testapp.bookshelf.BookshelfFragment"
        android:label="Библиотека"
        tools:layout="@layout/fragment_bookshelf" />

    <!-- История чтения -->
    <fragment
        android:id="@+id/historyFragment"
        android:name="org.readium.r2.testapp.history.HistoryFragment"
        android:label="История чтения"
        tools:layout="@layout/fragment_history" />

    <!-- Будильник - настройки -->
    <fragment
        android:id="@+id/alarm_fragment"
        android:name="org.readium.r2.testapp.alarm.AlarmFragment"
        android:label="Будильник"
        tools:layout="@layout/fragment_alarm" />

    <!-- Будильник - статистика -->
    <fragment
        android:id="@+id/sleepStatsFragment"
        android:name="org.readium.r2.testapp.alarm.SleepStatsFragment"
        android:label="Статистика сна"
        tools:layout="@layout/fragment_sleep_stats" />

    <!-- Действия (actions) -->
    <action
        android:id="@+id/action_menu_to_bookshelf"
        app:destination="@id/bookshelf_fragment" />

    <action
        android:id="@+id/action_menu_to_alarm"
        app:destination="@id/alarm_fragment" />

    <action
        android:id="@+id/action_alarm_to_stats"
        app:destination="@id/sleepStatsFragment" />

    <action
        android:id="@+id/action_bookshelf_to_history"
        app:destination="@id/historyFragment" />

</navigation>